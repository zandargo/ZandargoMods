<configs>
	<!-- ====================== BASIC SURVIVAL KIT ====================== -->
	<append xpath="/lootcontainers">
		<lootgroup name="groupBasicSurvival" count="1">
			<item name="meleeToolPickT2SteelPickaxe" count="1" prob="1.0" />
		</lootgroup>
	</append>
	<append xpath="/lootcontainers">
		<lootcontainer name="basicSurvivalLoot" count="1" size="8,12"
                       sound_open="UseActions/open_backpack" sound_close="UseActions/close_backpack"
                       open_time="0.5" loot_quality_template="qualBaseTemplate">
			<item group="groupBasicSurvival" count="1" prob="1.0" />
		</lootcontainer>
	</append>
	<!-- ====================== RESOURCE HEAVY KIT ====================== -->
	<append xpath="/lootcontainers">
		<lootgroup name="groupResourceHeavy" count="1">
			<item name="resourceWoodBundle" count="1" prob="1.0" />
		</lootgroup>
	</append>
	<append xpath="/lootcontainers">
		<lootcontainer name="resourceHeavyLoot" count="1" size="12,18"
                       sound_open="UseActions/open_chest" sound_close="UseActions/close_chest"
                       open_time="0.5" loot_quality_template="qualBaseTemplate">
			<item group="groupResourceHeavy" count="1" prob="1.0" />
		</lootcontainer>
	</append>
	<!-- ====================== IMPORTANT ITEMS FULL LIST ====================== -->
	<append xpath="/lootcontainers">
		<lootgroup name="groupStartingKit" count="1">
			<item name="meleeWpnBladeT3Machete" count="1" prob="1.0" />
		</lootgroup>
	</append>
	<append xpath="/lootcontainers">
		<lootcontainer name="startingKitLoot" count="1" size="10,15"
                       sound_open="UseActions/open_chest" sound_close="UseActions/close_chest"
                       open_time="0.5" loot_quality_template="qualBaseTemplate">
			<item group="groupStartingKit" count="1" prob="1.0" />
		</lootcontainer>
	</append>
</configs>