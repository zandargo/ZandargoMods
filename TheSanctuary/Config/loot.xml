         <item name="resourceScrapIronBundle" count="5,5"/>
         <item name="resourceCrushedSandBundle" count="5,5"/>
         <item name="resourceCrushedSand" count="6000,6000"/>
         <item name="resourceOilShaleBundle" count="5,5"/>
         <item name="resourceCoalBundle" count="5,5"/>
         <item name="resourceLeadBundle" count="5,5"/>
         <item name="toolForgeCrucible" count="1,1"/>
         <item name="resourceAcid" count="20,20"/>
         <item name="resourceBone" count="1200,1200"/>
         <item name="ammoGasCanBundle" count="2,2"/>
         <item name="resourceMetalPipe" count="500,500"/>
         <item name="resourceScrapPolymers" count="1000,1000"/>
         <item name="resourceSewingKit" count="50,50"/>
         <item name="resourceScrapBrass" count="6000,6000"/>
         <item name="resourceClayLump" count="6000,6000"/>
         <item name="resourceLeather" count="250,250"/>
         <item name="resourceLeather" count="250,250"/>
         <item name="resourceCloth" count="250,250"/>
         <item name="resourceCloth" count="250,250"/>
         <item name="resourceCloth" count="250,250"/>
         <item name="resourcePaper" count="150,150"/>
