<configs>
   <!-- ====================== BASIC SURVIVAL KIT ====================== -->
   <append xpath="/lootcontainers">
      <lootgroup name="groupBasicSurvival" count="all">
         <!-- === Tools & Armor === -->
         <item name="meleeToolPickT2SteelPickaxe" count="1,1"/>
         <item name="meleeToolAxeT2SteelAxe" count="1,1"/>
         <item name="meleeToolShovelT2SteelShovel" count="1,1"/>
         <item name="meleeToolRepairT1ClawHammer" count="1,1"/>
         <item name="meleeToolSalvageT2Ratchet" count="1,1"/>
         <!-- === Weapons & Ammo === -->
         <item name="meleeWpnBladeT3Machete" count="1,1"/>
         <item name="meleeWpnSpearT3SteelSpear" count="1,1"/>
         <item name="gunRifleT3SniperRifle" count="1,1"/>
         <item name="modGunSoundSuppressorSilencer" count="1,1"/>
         <item name="modGunScopeLarge" count="1,1"/>
         <item name="ammo762mmBulletBall" count="150,150"/>
         <item name="gunBowT3CompoundBow" count="1,1"/>
         <item name="ammoArrowSteelAP" count="150,150"/>
         <item name="armorAssassinHelmet" count="1,1"/>
         <item name="armorAssassinOutfit" count="1,1"/>
         <item name="armorAssassinGloves" count="1,1"/>
         <item name="armorAssassinBoots" count="1,1"/>
         <item name="modArmorNightVision" count="1,1"/>
         <!-- === Survival === -->
         <item name="drinkJarPureMineralWater" count="10,10"/>
         <item name="foodHoboStew" count="10,10"/>
         <item name="medicalFirstAidKit" count="3,3"/>
      </lootgroup>
   </append>
   <append xpath="/lootcontainers">
      <lootcontainer name="basicSurvivalLoot" count="all" size="8,12"
                       sound_open="UseActions/open_backpack" sound_close="UseActions/close_backpack"
                       open_time="0.5" loot_quality_template="qualBaseTemplate">
         <item group="groupBasicSurvival" count="all"/>
      </lootcontainer>
   </append>
   <!-- ====================== RESOURCE HEAVY KIT ====================== -->
   <append xpath="/lootcontainers">
      <lootgroup name="groupResourceHeavy" count="all">
