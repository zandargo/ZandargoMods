         <item name="bowsSkillMagazine" count="20,20"/>
         <item name="vehicleAdventures" count="20,20"/>
         <item name="homeCookingWeekly" count="20,20"/>
      </lootgroup>
   </append>
   <append xpath="/lootcontainers">
      <lootcontainer name="resourceHeavyLoot" count="all" size="12,18"
                       sound_open="UseActions/open_chest" sound_close="UseActions/close_chest"
                       open_time="0.5" loot_quality_template="qualBaseTemplate">
